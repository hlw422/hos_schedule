.calendar {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.week-header {
  display: flex;
  justify-content: space-around;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #999;
}

.dates {
  display: flex;
  flex-wrap: wrap;
}

.date-item {
  width: 14.28%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #333;
}

.date-item.today {
  color: #1677FF;
  font-weight: bold;
}

.date-item.has-schedule {
  background: #e6f4ff;
  border-radius: 8rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  background: #1677FF;
  border-radius: 50%;
  margin-top: 4rpx;
}

.schedule-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.schedule-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.period {
  font-size: 30rpx;
  color: #333;
}

.count {
  font-size: 28rpx;
  color: #1677FF;
}
