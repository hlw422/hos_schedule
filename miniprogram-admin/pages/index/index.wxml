<view class="container">
  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-value">{{stats.total}}</text>
      <text class="stat-label">今日预约</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.paid}}</text>
      <text class="stat-label">已支付</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.completed}}</text>
      <text class="stat-label">已完成</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.cancelled}}</text>
      <text class="stat-label">已取消</text>
    </view>
  </view>
  <view class="section">
    <text class="section-title">今日预约列表</text>
    <view class="list" wx:if="{{appointments.length > 0}}">
      <view class="item" wx:for="{{appointments}}" wx:key="id">
        <text>{{item.patient_name}}</text>
        <text>{{item.time_period}}</text>
        <text class="status {{item.status === '已取消' ? 'cancelled' : ''}}">{{item.status}}</text>
      </view>
    </view>
    <view class="empty" wx:else>
      <text>暂无预约</text>
    </view>
  </view>
</view>
