.hospital-header {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.hospital-logo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
}

.hospital-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.hospital-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.hospital-tags {
  display: flex;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.card-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.campus-tabs {
  display: flex;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 20rpx;
}

.campus-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666666;
  border-radius: 8rpx;
}

.campus-tab.active {
  background: #1677FF;
  color: #ffffff;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  display: block;
}

.dept-list {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 0 24rpx;
}

.dept-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.dept-item:last-child {
  border-bottom: none;
}

.dept-info {
  flex: 1;
}

.dept-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.dept-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  display: block;
}

.arrow-icon {
  width: 32rpx;
  height: 32rpx;
}
