.success-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 24rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #52C41A;
  margin-bottom: 12rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #999999;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999999;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
}

.tips {
  display: flex;
  flex-direction: column;
}

.tip-item {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}

.btn-group {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-secondary {
  flex: 1;
  background: #ffffff;
  color: #1677FF;
  border: 2rpx solid #1677FF;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
}

.btn-primary {
  flex: 1;
  background: #1677FF;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  font-size: 32rpx;
}
