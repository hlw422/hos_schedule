.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 16rpx;
  display: block;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.add-btn {
  font-size: 28rpx;
  color: #1677FF;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999999;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
}

.info-value.fee {
  color: #FA8C16;
  font-weight: bold;
}

.patient-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.patient-item.selected {
  border-color: #1677FF;
  background: #E6F4FF;
}

.patient-info {
  display: flex;
  flex-direction: column;
}

.patient-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 8rpx;
}

.patient-id {
  font-size: 24rpx;
  color: #999999;
}

.check-icon {
  width: 40rpx;
  height: 40rpx;
}

.empty-patient {
  text-align: center;
  padding: 40rpx;
  font-size: 28rpx;
  color: #999999;
}

.symptom-input {
  width: 100%;
  height: 200rpx;
  font-size: 28rpx;
  padding: 16rpx;
  background: #F7F8FA;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: #ffffff;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}
