<view class="container">
  <form bindsubmit="submit">
    <!-- 姓名 -->
    <view class="form-item">
      <text class="form-label">姓名</text>
      <input class="form-input" placeholder="请输入真实姓名" value="{{form.name}}" bindinput="onInput" data-field="name" />
    </view>

    <!-- 身份证号 -->
    <view class="form-item">
      <text class="form-label">身份证号</text>
      <input class="form-input" placeholder="请输入身份证号" value="{{form.id_card}}" bindinput="onInput" data-field="id_card" type="idcard" />
    </view>

    <!-- 手机号 -->
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onInput" data-field="phone" type="number" maxlength="11" />
    </view>

    <!-- 性别 -->
    <view class="form-item">
      <text class="form-label">性别</text>
      <view class="gender-select">
        <view class="gender-option {{form.gender === 1 ? 'active' : ''}}" bindtap="selectGender" data-gender="1">男</view>
        <view class="gender-option {{form.gender === 2 ? 'active' : ''}}" bindtap="selectGender" data-gender="2">女</view>
      </view>
    </view>

    <!-- 出生日期 -->
    <view class="form-item">
      <text class="form-label">出生日期</text>
      <picker mode="date" value="{{form.birthday}}" bindchange="onBirthdayChange">
        <view class="form-input picker">{{form.birthday || '请选择出生日期'}}</view>
      </picker>
    </view>

    <!-- 设为默认 -->
    <view class="form-item switch-item">
      <text class="form-label">设为默认就诊人</text>
      <switch checked="{{form.is_default}}" bindchange="onDefaultChange" color="#1677FF" />
    </view>

    <!-- 提交按钮 -->
    <view class="btn-group">
      <button class="btn-primary" form-type="submit" disabled="{{submitting}}">
        {{submitting ? '保存中...' : (isEdit ? '保存修改' : '添加就诊人')}}
      </button>
    </view>
  </form>
</view>
