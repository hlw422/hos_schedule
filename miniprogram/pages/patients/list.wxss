.patient-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.patient-info {
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.patient-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.patient-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin-right: 12rpx;
}

.default-tag {
  font-size: 22rpx;
  color: #1677FF;
  background: #E6F4FF;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.patient-id {
  font-size: 26rpx;
  color: #666666;
  display: block;
  margin-bottom: 8rpx;
}

.patient-phone {
  font-size: 26rpx;
  color: #666666;
  display: block;
}

.patient-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
  gap: 20rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #1677FF;
  padding: 8rpx 24rpx;
  border: 2rpx solid #1677FF;
  border-radius: 8rpx;
}

.action-btn.delete {
  color: #FF4D4F;
  border-color: #FF4D4F;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: #ffffff;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}
