.form-item {
  background: #ffffff;
  padding: 24rpx;
  margin-bottom: 2rpx;
}

.form-item:first-child {
  border-radius: 16rpx 16rpx 0 0;
}

.form-item:last-of-type {
  border-radius: 0 0 16rpx 16rpx;
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  font-size: 28rpx;
  padding: 0 16rpx;
  background: #F7F8FA;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.picker {
  line-height: 80rpx;
  color: #999999;
}

.gender-select {
  display: flex;
  gap: 20rpx;
}

.gender-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666666;
  background: #F7F8FA;
  border-radius: 8rpx;
  border: 2rpx solid transparent;
}

.gender-option.active {
  color: #1677FF;
  background: #E6F4FF;
  border-color: #1677FF;
}

.switch-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.switch-item .form-label {
  margin-bottom: 0;
}

.btn-group {
  margin-top: 40rpx;
}
